<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    <link rel="stylesheet" href="{{ 'antara-luxury.css' | asset_url }}">
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height calculation to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight() and updateTransparentHeaderOffset()utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
      // Badge hunter: hides injected payment/trust badges anywhere in the DOM.
      (function hideInjectedPaymentBadges() {
        var CART_SELECTOR = '.cart, .cart-drawer, [id*="cart"]';
        var BADGE_PHRASES = ['secure checkout with', 'secure checkout', 'checkout securely'];

        function containsBadgeText(el) {
          var text = (el.textContent || '').toLowerCase();
          return BADGE_PHRASES.some(function(k) { return text.includes(k); });
        }

        function hideEl(el) {
          el.style.setProperty('display', 'none', 'important');
          el.style.setProperty('visibility', 'hidden', 'important');
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('pointer-events', 'none', 'important');
        }

        function hideTrustBadgeBear() {
          // Trust Badge Bear app: #trust-bar iframe and #ultimateTrustBadgeswidgetDiv
          ['trust-bar', 'ultimateTrustBadgeswidgetDiv'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) hideEl(el);
          });
          // Also catch by iframe title
          document.querySelectorAll('iframe[title="trust-badges-widget"]').forEach(function(el) {
            hideEl(el);
            if (el.parentElement) hideEl(el.parentElement);
          });
        }

        function scanElement(el) {
          if (!el || el.nodeType !== 1) return;
          var inCart = el.closest && el.closest(CART_SELECTOR);
          if (inCart) return;
          var tag = el.tagName ? el.tagName.toLowerCase() : '';

          if (tag === 'shopify-cleanslate') { hideEl(el); return; }
          if (el.className && typeof el.className === 'string' && el.className.includes('shopify-payment-button')) { hideEl(el); return; }
          if (el.getAttribute && el.getAttribute('data-shopify') === 'payment-button') { hideEl(el); return; }

          if (el.shadowRoot) {
            var shadowText = (el.shadowRoot.textContent || '').toLowerCase();
            if (BADGE_PHRASES.some(function(k) { return shadowText.includes(k); })) { hideEl(el); return; }
          }

          if (tag === 'iframe' && (el.title || '').toLowerCase().includes('trust')) { hideEl(el); return; }

          if (containsBadgeText(el) && (tag === 'div' || tag === 'span' || tag === 'section' || tag === 'aside')) {
            hideEl(el);
          }
        }

        function run() {
          hideTrustBadgeBear();
          document.querySelectorAll('shopify-cleanslate').forEach(function(el) {
            if (!el.closest(CART_SELECTOR)) el.style.setProperty('display', 'none', 'important');
          });
          document.querySelectorAll('.shopify-payment-button, [data-shopify="payment-button"]').forEach(function(el) {
            if (!el.closest(CART_SELECTOR)) el.style.setProperty('display', 'none', 'important');
          });
          document.querySelectorAll('*').forEach(scanElement);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }

        new MutationObserver(function(mutations) {
          if (mutations.some(function(m) { return m.addedNodes.length > 0; })) {
            run();
          }
        }).observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <script>
      // ============================================================
      // ANTARA PREMIUM ANIMATIONS
      // 1. Custom Cursor  2. Text Reveal  3. Page Transitions
      // ============================================================
      (function antaraPremiumAnimations() {
        'use strict';

        // ── 1. CUSTOM CURSOR ──────────────────────────────────────
        var hasFinePointer = window.matchMedia('(pointer: fine)').matches;

        if (hasFinePointer) {
          var ring = document.createElement('div');
          ring.id = 'antara-cursor';
          var dot = document.createElement('div');
          dot.id = 'antara-cursor-dot';
          document.body.appendChild(ring);
          document.body.appendChild(dot);

          var mx = -200, my = -200;
          var rx = -200, ry = -200;
          var rafCursor;

          document.addEventListener('mousemove', function(e) {
            mx = e.clientX; my = e.clientY;
            dot.style.left = mx + 'px';
            dot.style.top  = my + 'px';
            document.body.classList.remove('antara-cursor-hidden');
          });

          // Smooth lag on the ring via lerp
          (function lerpCursor() {
            rx += (mx - rx) * 0.13;
            ry += (my - ry) * 0.13;
            ring.style.left = rx + 'px';
            ring.style.top  = ry + 'px';
            requestAnimationFrame(lerpCursor);
          })();

          var HOVER_SEL = 'a, button, [role="button"], input, select, textarea, label, .product-card, .card, .btn';
          document.addEventListener('mouseover', function(e) {
            if (e.target.closest(HOVER_SEL)) document.body.classList.add('antara-cursor-hover');
          });
          document.addEventListener('mouseout', function(e) {
            if (e.target.closest(HOVER_SEL)) document.body.classList.remove('antara-cursor-hover');
          });
          document.addEventListener('mouseleave', function() { document.body.classList.add('antara-cursor-hidden'); });
          document.addEventListener('mouseenter', function() { document.body.classList.remove('antara-cursor-hidden'); });
        }

        // ── 2. TEXT REVEAL ────────────────────────────────────────
        function wrapWords(el) {
          if (el.children.length > 0) return false; // skip if contains HTML children
          var text = el.textContent.trim();
          if (!text) return false;
          el.innerHTML = text.split(/\s+/).map(function(w) {
            return '<span class="antara-word"><span class="antara-word-inner">' + w + '</span></span>';
          }).join(' ');
          return true;
        }

        function initReveal() {
          var REVEAL_SEL = [
            'main h1', 'main h2', 'main h3',
            '.hero__title', '.section__heading',
            '.section__subheading', '.rich-text__heading',
            '.title-wrapper h2', '.title-wrapper h3'
          ].join(', ');

          document.querySelectorAll(REVEAL_SEL).forEach(function(el) {
            if (el.closest('header, nav, .header') || el.dataset.ar) return;
            el.dataset.ar = '1';
            if (!wrapWords(el)) return;
            el.classList.add('antara-text-reveal');
          });

          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (!entry.isIntersecting) return;
              var el = entry.target;
              el.querySelectorAll('.antara-word-inner').forEach(function(inner, i) {
                inner.style.transitionDelay = (i * 65) + 'ms';
              });
              el.classList.add('antara-text-revealed');
              observer.unobserve(el);
            });
          }, { threshold: 0.15 });

          document.querySelectorAll('.antara-text-reveal').forEach(function(el) {
            observer.observe(el);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initReveal);
        } else {
          initReveal();
        }

        // ── 3. PAGE TRANSITIONS ───────────────────────────────────
        var overlay = document.createElement('div');
        overlay.id = 'antara-page-overlay';
        var wordmark = document.createElement('span');
        wordmark.id = 'antara-page-overlay-wordmark';
        wordmark.textContent = 'ANTARA';
        overlay.appendChild(wordmark);
        document.body.insertBefore(overlay, document.body.firstChild);

        // Fade in on arrival
        requestAnimationFrame(function() {
          overlay.classList.remove('antara-leaving');
        });

        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href]');
          if (!link) return;
          var href = link.getAttribute('href');
          if (
            !href || href.startsWith('#') || href.startsWith('javascript') ||
            href.startsWith('mailto:') || href.startsWith('tel:') ||
            link.target === '_blank' || link.hasAttribute('download') ||
            e.ctrlKey || e.metaKey || e.shiftKey || e.altKey
          ) return;
          // Skip cart/drawer/search interactions
          if (link.closest('form, [data-drawer-open], [data-quick-add], .cart, .search')) return;

          e.preventDefault();
          overlay.classList.add('antara-leaving');
          // Navigate after fade is fully solid (450ms), new page fades in via CSS on arrival
          setTimeout(function() { window.location.href = href; }, 500);
        });

        // Handle browser back/forward (bfcache)
        window.addEventListener('pageshow', function(e) {
          if (e.persisted) overlay.classList.remove('antara-leaving');
        });

      })();
    </script>
  </body>
</html>
