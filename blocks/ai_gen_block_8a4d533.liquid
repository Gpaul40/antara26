{% doc %}
  @prompt
    I made a page thats called Our People and it has info about the Antara Team. i want to put it in a block here so that people can gain interest into reading about who runs antara. it will need to look nice though the block maybe it has a picture of a team or something labelled our people that you click and it takes you to the page, maybe it has a small summary in it somewhere, is it possible for thetext and buttons to be ontop of the image and be kind of transparent so it looks fancy
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-our-people-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-our-people-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    height: {{ block.settings.image_height }}px;
  }

  .ai-our-people-image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-our-people-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-our-people-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-our-people-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-our-people-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
  }

  .ai-our-people-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    z-index: 2;
  }

  .ai-our-people-heading-{{ ai_gen_id }} {
    margin: 0 0 12px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .ai-our-people-summary-{{ ai_gen_id }} {
    margin: 0 0 20px 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-our-people-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    backdrop-filter: blur({{ block.settings.button_blur }}px);
  }

  .ai-our-people-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-our-people-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-our-people-link-{{ ai_gen_id }}:hover .ai-our-people-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  @media screen and (max-width: 749px) {
    .ai-our-people-container-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }

    .ai-our-people-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-our-people-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<our-people-block-{{ ai_gen_id }}
  class="ai-our-people-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-our-people-container-{{ ai_gen_id }}">
    <div class="ai-our-people-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | default: 'Our People' | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-our-people-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-our-people-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-our-people-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-our-people-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-our-people-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h3>
      {% endif %}

      {% if block.settings.summary != blank %}
        <div class="ai-our-people-summary-{{ ai_gen_id }}">
          {{ block.settings.summary }}
        </div>
      {% endif %}

      {% if block.settings.page_link %}
        <a
          href="{{ block.settings.page_link }}"
          class="ai-our-people-link-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
          <svg
            class="ai-our-people-arrow-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</our-people-block-{{ ai_gen_id }}>

<script>
  (function() {
    class OurPeopleBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('our-people-block-{{ ai_gen_id }}', OurPeopleBlock{{ ai_gen_id }});
  })();
</script>

