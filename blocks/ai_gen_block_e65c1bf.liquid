{% doc %}
  @prompt
    can you create a product grid for new items , make this full width 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-new-items-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-new-items-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-new-items-grid__heading-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-new-items-grid__subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-new-items-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-new-items-grid__item-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-new-items-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-new-items-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-new-items-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-new-items-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-new-items-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-new-items-grid__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 2px;
  }

  .ai-new-items-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-new-items-grid__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    line-height: 1.3;
  }

  .ai-new-items-grid__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-new-items-grid__title-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-new-items-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-new-items-grid__button-{{ ai_gen_id }} {
    margin-top: auto;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-new-items-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-new-items-grid__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-new-items-grid__empty-state-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  .ai-new-items-grid__empty-message-{{ ai_gen_id }} {
    font-size: 16px;
    margin-bottom: 8px;
  }

  .ai-new-items-grid__empty-hint-{{ ai_gen_id }} {
    font-size: 14px;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-new-items-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-new-items-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-new-items-grid__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<new-items-grid-{{ ai_gen_id }}
  class="ai-new-items-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-new-items-grid__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-new-items-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-new-items-grid__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.collection != blank %}
    {% assign products = block.settings.collection.products | limit: block.settings.products_to_show %}
    
    {% if products.size > 0 %}
      <div class="ai-new-items-grid__container-{{ ai_gen_id }}">
        {% for product in products %}
          <div class="ai-new-items-grid__item-{{ ai_gen_id }}">
            <div class="ai-new-items-grid__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-new-items-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-new-items-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_badge %}
                <div class="ai-new-items-grid__badge-{{ ai_gen_id }}">
                  {{ block.settings.badge_text }}
                </div>
              {% endif %}
            </div>

            <div class="ai-new-items-grid__content-{{ ai_gen_id }}">
              <h3 class="ai-new-items-grid__title-{{ ai_gen_id }}">
                <a
                  href="{{ product.url }}"
                  class="ai-new-items-grid__title-link-{{ ai_gen_id }}"
                >
                  {{ product.title }}
                </a>
              </h3>

              {% if block.settings.show_price %}
                <div class="ai-new-items-grid__price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>
              {% endif %}

              {% if block.settings.show_button %}
                <a
                  href="{{ product.url }}"
                  class="ai-new-items-grid__button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-new-items-grid__empty-state-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
        <div class="ai-new-items-grid__empty-message-{{ ai_gen_id }}">
          No products in this collection yet
        </div>
        <div class="ai-new-items-grid__empty-hint-{{ ai_gen_id }}">
          Add products to see them here
        </div>
      </div>
    {% endif %}
  {% else %}
    <div class="ai-new-items-grid__empty-state-{{ ai_gen_id }}">
      {{ 'collection-1' | placeholder_svg_tag }}
      <div class="ai-new-items-grid__empty-message-{{ ai_gen_id }}">
        Select a collection to display
      </div>
      <div class="ai-new-items-grid__empty-hint-{{ ai_gen_id }}">
        Choose a collection from the block settings
      </div>
    </div>
  {% endif %}
</new-items-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class NewItemsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const images = this.querySelectorAll('.ai-new-items-grid__image-{{ ai_gen_id }}');
        images.forEach(img => {
          if (!img.alt) {
            img.setAttribute('alt', 'Product image');
          }
        });
      }
    }

    customElements.define('new-items-grid-{{ ai_gen_id }}', NewItemsGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "New items grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
