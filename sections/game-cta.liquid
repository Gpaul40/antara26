{% comment %} The Edit — Centered game CTA banner {% endcomment %}
<div class="agc-wrap">
  <button class="agc-btn" onclick="antaraOpenPopup()" aria-label="Play The Edit">
    <span class="agc-ring agc-ring-1"></span>
    <span class="agc-ring agc-ring-2"></span>
    <span class="agc-inner">
      <svg class="agc-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polygon points="6,3 20,12 6,21" fill="currentColor"/>
      </svg>
      <span class="agc-text">
        <span class="agc-label">PLAY THE EDIT</span>
        <span class="agc-sub">Match the pieces — WIN 30% OFF</span>
      </span>
    </span>
  </button>
</div>

<style>
  .agc-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 28px 20px;
    background: #fff;
    width: 100%;
    box-sizing: border-box;
    text-align: center;
  }

  /* override Shopify theme container constraints */
  .shopify-section:has(.agc-wrap),
  .shopify-section .agc-wrap {
    max-width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  .agc-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    background: #0a0a0a;
    border: 1px solid rgba(201,169,110,0.7);
    border-radius: 60px;
    padding: 14px 32px 14px 22px;
    cursor: pointer;
    gap: 14px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    box-shadow: 0 4px 28px rgba(201,169,110,0.18);
  }
  .agc-btn:hover {
    transform: translateY(-3px) scale(1.04);
    border-color: #c9a96e;
    box-shadow: 0 10px 44px rgba(201,169,110,0.38);
  }
  .agc-btn:active { transform: scale(0.98); }

  /* pulsing rings */
  .agc-ring {
    position: absolute;
    inset: -1px;
    border-radius: 60px;
    border: 1px solid rgba(201,169,110,0.45);
    animation: agcPulse 2.6s ease-out infinite;
    pointer-events: none;
  }
  .agc-ring-2 { animation-delay: 1.3s; }
  @keyframes agcPulse {
    0%   { transform: scale(1);    opacity: 0.8; }
    100% { transform: scale(1.65); opacity: 0; }
  }

  /* shimmer on hover */
  .agc-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 60px;
    background: linear-gradient(105deg, transparent 40%, rgba(201,169,110,0.13) 50%, transparent 60%);
    background-size: 200% 100%;
    background-position: 200% 0;
    transition: background-position 0.5s ease;
    pointer-events: none;
  }
  .agc-btn:hover::after { background-position: -100% 0; }

  .agc-icon {
    width: 20px;
    height: 20px;
    color: #c9a96e;
    flex-shrink: 0;
  }

  .agc-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .agc-label {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
  }
  .agc-sub {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(201,169,110,0.6);
    line-height: 1.2;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .agc-wrap { padding: 20px 16px; }
    .agc-label { font-size: 11px; }
    .agc-sub { font-size: 9px; }
  }
</style>

{% schema %}
{
  "name": "Game CTA",
  "settings": [],
  "presets": [
    { "name": "Game CTA" }
  ]
}
{% endschema %}
