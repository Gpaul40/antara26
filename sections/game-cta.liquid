{% comment %} The Edit — scrolling ticker banner {% endcomment %}
<p class="agc-seo-text">
  Play The Edit — Antara International's exclusive memory challenge. Win 30% off your next order.
  <a href="/pages/the-edit">Learn more about The Edit</a>
</p>
<div class="agc-ticker-wrap" role="banner">
  <button class="agc-ticker-track" onclick="antaraOpenPopup()" aria-label="Play The Edit — Win 30% off">
    <span class="agc-ticker-inner" aria-hidden="true">
      {%- for i in (1..8) -%}
        <span class="agc-ticker-item">
          <svg class="agc-ticker-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="6,3 20,12 6,21" fill="currentColor"/></svg>
          <span class="agc-ticker-label">PLAY THE EDIT</span>
          <span class="agc-ticker-sep">&nbsp;&nbsp;·&nbsp;&nbsp;</span>
          <span class="agc-ticker-sub">WIN 30% OFF</span>
          <span class="agc-ticker-sep">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </span>
      {%- endfor -%}
    </span>
    <span class="agc-ticker-inner agc-ticker-inner--clone" aria-hidden="true">
      {%- for i in (1..8) -%}
        <span class="agc-ticker-item">
          <svg class="agc-ticker-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="6,3 20,12 6,21" fill="currentColor"/></svg>
          <span class="agc-ticker-label">PLAY THE EDIT</span>
          <span class="agc-ticker-sep">&nbsp;&nbsp;·&nbsp;&nbsp;</span>
          <span class="agc-ticker-sub">WIN 30% OFF</span>
          <span class="agc-ticker-sep">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </span>
      {%- endfor -%}
    </span>
  </button>
</div>

<style>
  /* ── SEO text (visible to crawlers, hidden visually) ──────── */
  .agc-seo-text {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Ticker banner ───────────────────────────────────────── */
  .agc-ticker-wrap {
    width: 100%;
    overflow: hidden;
    background: #0d0d0d;
    border-top: 1px solid rgba(201,169,110,0.2);
    border-bottom: 1px solid rgba(201,169,110,0.2);
    cursor: pointer;
    user-select: none;
  }

  /* Kill Shopify section wrapper spacing */
  .shopify-section:has(.agc-ticker-wrap) {
    margin: 0 !important;
    padding: 0 !important;
  }

  .agc-ticker-track {
    display: flex;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
  }
  .agc-ticker-track:hover .agc-ticker-inner {
    animation-play-state: paused;
  }

  .agc-ticker-inner {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    white-space: nowrap;
    padding: 13px 0;
    animation: agcTicker 28s linear infinite;
  }
  .agc-ticker-inner--clone {
    animation-delay: -14s;
  }

  @keyframes agcTicker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .agc-ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .agc-ticker-icon {
    width: 11px;
    height: 11px;
    color: #c9a96e;
    flex-shrink: 0;
  }

  .agc-ticker-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
  }

  .agc-ticker-sep {
    color: rgba(201,169,110,0.35);
    font-size: 11px;
  }

  .agc-ticker-sub {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201,169,110,0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    .agc-ticker-inner { animation: none; }
    .agc-ticker-inner--clone { display: none; }
  }
</style>

{% schema %}
{
  "name": "Game CTA",
  "settings": [],
  "presets": [
    { "name": "Game CTA" }
  ]
}
{% endschema %}
