{% comment %} The Edit — Dedicated SEO landing page {% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I win 30% off at Antara International?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Play The Edit memory challenge on the Antara International website. Match all pairs across both levels within the time limit. Once you complete the game, your exclusive 30% discount code is revealed."
      }
    },
    {
      "@type": "Question",
      "name": "What is The Edit by Antara International?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Edit is an exclusive interactive memory card game created by Antara International. It is a luxury challenge featuring 44 pairs across 2 levels. Players who complete The Edit earn 30% off their next order as The Collector tier reward."
      }
    },
    {
      "@type": "Question",
      "name": "How many levels does The Edit memory game have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Edit features 2 levels with 44 pairs each. Every successful match adds +10 seconds to your timer, rewarding accuracy and focus."
      }
    },
    {
      "@type": "Question",
      "name": "Is The Edit memory game free to play?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The Edit is completely free to play on the Antara International website. No purchase is required to enter the challenge."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Collector tier discount?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Collector is the reward tier for completing The Edit memory challenge. Players who match all pairs across both levels within the time limit unlock a 30% discount off their next Antara International order."
      }
    }
  ]
}
</script>

<div class="agp-page">
  <div class="agp-page__inner">

    <div class="agp-page__header">
      <p class="agp-page__eyebrow">ANTARA INTERNATIONAL</p>
      <h1 class="agp-page__title">THE EDIT</h1>
      <p class="agp-page__tagline">A MEMORY CHALLENGE FOR THOSE WHO MOVE WITH INTENTION.</p>
    </div>

    <div class="agp-page__body">
      <p class="agp-page__desc">
        The Edit is Antara International's exclusive memory card game — an interactive luxury challenge that rewards precision, focus, and speed.
        Match every pair, beat the clock, and earn <strong>30% off your next order</strong>.
      </p>

      <div class="agp-page__tier">
        <h2 class="agp-page__subhead">THE COLLECTOR — HOW TO WIN</h2>
        <ul class="agp-page__list">
          <li>2 levels &middot; 44 pairs each</li>
          <li>Every match earns +10 seconds on the clock</li>
          <li>Complete both levels to unlock your discount</li>
          <li>Reward: <strong>30% off your next order</strong></li>
        </ul>
      </div>

      <button class="agp-page__cta" onclick="antaraOpenPopup()" aria-label="Play The Edit — Win 30% off">
        PLAY NOW
      </button>

      <div class="agp-page__faq">
        <h2 class="agp-page__faq-heading">FREQUENTLY ASKED QUESTIONS</h2>

        <details class="agp-page__faq-item">
          <summary>How do I win 30% off?</summary>
          <p>Match all pairs across both levels within the time limit. Once you complete The Edit, your exclusive 30% discount code is revealed instantly.</p>
        </details>

        <details class="agp-page__faq-item">
          <summary>Is The Edit free to play?</summary>
          <p>Yes — completely free. No purchase necessary. The game is open to all visitors on the Antara International website.</p>
        </details>

        <details class="agp-page__faq-item">
          <summary>How many levels are there?</summary>
          <p>The Edit has 2 levels, each featuring 44 pairs. Every successful match earns +10 seconds on the clock, so accuracy matters.</p>
        </details>

        <details class="agp-page__faq-item">
          <summary>What is The Collector tier?</summary>
          <p>The Collector is the reward tier awarded to players who complete The Edit memory challenge. Finish both levels and unlock 30% off your next Antara International order.</p>
        </details>

        <details class="agp-page__faq-item">
          <summary>When does my discount expire?</summary>
          <p>Your discount details and expiry date are provided when you complete the challenge. Check your code for the specific terms.</p>
        </details>
      </div>
    </div>

  </div>
</div>

<style>
  .agp-page {
    background: #0d0d0d;
    color: #fff;
    padding: 80px 24px 100px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .agp-page__inner {
    max-width: 680px;
    margin: 0 auto;
  }
  .agp-page__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .agp-page__eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: #c9a96e;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .agp-page__title {
    font-size: clamp(56px, 10vw, 96px);
    font-weight: 300;
    letter-spacing: 0.12em;
    margin: 0 0 20px;
    line-height: 1;
  }
  .agp-page__tagline {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.7;
  }
  .agp-page__desc {
    font-size: 15px;
    line-height: 1.85;
    color: rgba(255,255,255,0.7);
    margin: 0 0 48px;
  }
  .agp-page__desc strong { color: #c9a96e; }
  .agp-page__subhead {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    font-weight: 600;
    margin: 0 0 20px;
  }
  .agp-page__tier {
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 0 0 48px;
  }
  .agp-page__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .agp-page__list li {
    font-size: 13px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.65);
    padding-left: 16px;
    position: relative;
  }
  .agp-page__list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #c9a96e;
  }
  .agp-page__list strong { color: #c9a96e; }
  .agp-page__cta {
    display: block;
    width: 200px;
    margin: 0 auto 64px;
    background: transparent;
    border: 1px solid #c9a96e;
    color: #c9a96e;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 16px 48px;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
  }
  .agp-page__cta:hover { background: #c9a96e; color: #0d0d0d; }
  .agp-page__faq {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 48px;
  }
  .agp-page__faq-heading {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    font-weight: 600;
    margin: 0 0 32px;
  }
  .agp-page__faq-item {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .agp-page__faq-item summary {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .agp-page__faq-item summary::-webkit-details-marker { display: none; }
  .agp-page__faq-item summary::after {
    content: '+';
    color: #c9a96e;
    font-size: 20px;
    font-weight: 300;
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.2s;
  }
  .agp-page__faq-item[open] summary::after { transform: rotate(45deg); }
  .agp-page__faq-item p {
    font-size: 13px;
    line-height: 1.75;
    color: rgba(255,255,255,0.5);
    padding: 0 0 20px;
    margin: 0;
  }

  @media (max-width: 600px) {
    .agp-page { padding: 56px 20px 72px; }
    .agp-page__tier { padding: 20px 20px; }
  }
</style>

