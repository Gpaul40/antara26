{% comment %} The Edit — memory game popup {% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Offer",
  "name": "Win 30% Off — Play The Edit",
  "description": "Complete The Edit memory challenge by Antara International. Match all pairs across 2 levels to earn 30% off your next order as The Collector tier reward.",
  "url": "{{ shop.url }}/pages/the-edit",
  "seller": {
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "url": "{{ shop.url }}"
  },
  "itemOffered": {
    "@type": "Service",
    "name": "The Edit Memory Challenge",
    "description": "An exclusive interactive memory card game by Antara International featuring 2 levels and 44 pairs each.",
    "url": "{{ shop.url }}/pages/the-edit"
  }
}
</script>

<div id="antara-game-popup" class="agp-overlay" style="display:none" aria-modal="true" role="dialog">
  <div class="agp-backdrop"></div>
  <div class="agp-container">
    <button class="agp-close" aria-label="Close game" onclick="antaraClosePopup()">&times;</button>

    <!-- Intro splash screen (hidden — game handles its own intro) -->
    <div id="agp-intro" class="agp-intro" style="display:none"></div>

    <!-- Game iframe (hidden until BEGIN is clicked) -->
    <iframe
      id="agp-iframe"
      title="The Edit — Antara Memory Game"
      frameborder="0"
      allow="autoplay"
      style="display:none"
    ></iframe>
  </div>
</div>

<style>
  /* ── Popup overlay ───────────────────────────────────────── */
  .agp-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    animation: agpFadeIn 0.4s ease;
  }
  .agp-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    cursor: pointer;
  }
  .agp-backdrop:hover { background: rgba(0,0,0,0.9); }
  .agp-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    pointer-events: none;
  }

  /* ── Intro splash ────────────────────────────────────────── */
  .agp-intro {
    pointer-events: all;
    background: #0d0d0d;
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: 4px;
    max-width: 560px;
    width: 100%;
    padding: 52px 48px 44px;
    text-align: center;
    color: #fff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    box-shadow: 0 0 80px rgba(0,0,0,0.8);
  }
  .agp-eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: #c9a96e;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .agp-title {
    font-size: clamp(42px, 8vw, 72px);
    font-weight: 300;
    letter-spacing: 0.12em;
    margin: 0 0 18px;
    line-height: 1;
  }
  .agp-tagline {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .agp-rule {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.12);
    margin: 0 0 20px;
  }
  .agp-desc {
    font-size: 12px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    margin: 0 0 20px;
    line-height: 1.7;
  }
  .agp-tier {
    border: 1px solid rgba(201,169,110,0.35);
    border-radius: 4px;
    padding: 16px 20px;
    margin: 0 0 32px;
  }
  .agp-tier-name {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin: 0 0 4px;
  }
  .agp-tier-discount {
    font-size: 18px;
    letter-spacing: 0.1em;
    color: #c9a96e;
    font-weight: 600;
    margin: 0 0 6px;
  }
  .agp-tier-meta {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  /* ── Action buttons ──────────────────────────────────────── */
  .agp-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .agp-begin-btn {
    background: transparent;
    border: 1px solid #c9a96e;
    color: #c9a96e;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 14px 48px;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
    width: 200px;
  }
  .agp-begin-btn:hover {
    background: #c9a96e;
    color: #0d0d0d;
  }
  .agp-nothanks-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    font-size: 11px;
    letter-spacing: 0.1em;
    cursor: pointer;
    padding: 4px 8px;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-family: inherit;
    transition: color 0.2s;
  }
  .agp-nothanks-btn:hover { color: rgba(255,255,255,0.65); }

  /* ── Game iframe ─────────────────────────────────────────── */
  #agp-iframe {
    width: 100%;
    max-width: 900px;
    height: 90vh;
    max-height: 820px;
    border: none;
    border-radius: 4px;
    pointer-events: all;
    box-shadow: 0 0 80px rgba(0,0,0,0.8);
  }
  .agp-close {
    position: fixed;
    top: 16px;
    right: 20px;
    z-index: 100000;
    background: none;
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 22px;
    line-height: 1;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }
  .agp-close:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
  @keyframes agpFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (max-width: 600px) {
    .agp-container { padding: 0; align-items: flex-start; overflow-y: auto; }
    .agp-intro { border-radius: 0; padding: 40px 24px 36px; }
    #agp-iframe { max-width: 100%; height: 100vh; max-height: 100vh; border-radius: 0; }
    .agp-close { top: 12px; right: 12px; }
  }
</style>

<script>
  (function() {
    var SESSION_KEY = 'antara_game_seen';
    var DELAY_MS = 2000;

    function showPopup() {
      var el = document.getElementById('antara-game-popup');
      if (el) el.style.display = 'block';
      document.body.style.overflow = 'hidden';
      // Load game iframe directly — no separate intro screen
      var iframe = document.getElementById('agp-iframe');
      if (iframe) {
        if (!iframe.src || iframe.src === window.location.href) {
          iframe.src = 'https://antara-game.vercel.app';
        }
        iframe.style.display = 'block';
      }
    }

    window.antaraOpenPopup = function() {
      showPopup();
    };

    window.antaraBeginGame = function() {
      showPopup();
    };

    window.antaraClosePopup = function() {
      var el = document.getElementById('antara-game-popup');
      if (el) {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.3s';
        setTimeout(function() {
          el.style.display = 'none';
          el.style.opacity = '';
          var iframe = document.getElementById('agp-iframe');
          if (iframe) { iframe.style.display = 'none'; iframe.src = ''; }
        }, 300);
      }
      document.body.style.overflow = '';
      try { sessionStorage.setItem(SESSION_KEY, '1'); } catch(e) {}
    };

    document.addEventListener('DOMContentLoaded', function() {
      var backdrop = document.querySelector('.agp-backdrop');
      if (backdrop) backdrop.addEventListener('click', window.antaraClosePopup);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') window.antaraClosePopup();
      });

      // Auto-show once per session
      try {
        if (!sessionStorage.getItem(SESSION_KEY)) {
          setTimeout(showPopup, DELAY_MS);
        }
      } catch(e) {
        setTimeout(showPopup, DELAY_MS);
      }
    });
  })();
</script>
