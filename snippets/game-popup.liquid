{% comment %} The Edit — memory game popup {% endcomment %}
<div id="antara-game-popup" class="agp-overlay" style="display:none" aria-modal="true" role="dialog">
  <div class="agp-backdrop"></div>
  <div class="agp-container">
    <button class="agp-close" aria-label="Close game" onclick="antaraClosePopup()">&times;</button>
    <iframe
      id="agp-iframe"
      src="https://antara-game.vercel.app"
      title="The Edit — Antara Memory Game"
      frameborder="0"
      allow="autoplay"
      loading="lazy"
    ></iframe>
  </div>
</div>

<style>
  .agp-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    animation: agpFadeIn 0.4s ease;
  }
  .agp-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    cursor: pointer;
  }
  .agp-backdrop:hover { background: rgba(0,0,0,0.9); }
  .agp-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    pointer-events: none;
  }
  #agp-iframe {
    width: 100%;
    max-width: 900px;
    height: 90vh;
    max-height: 820px;
    border: none;
    border-radius: 4px;
    pointer-events: all;
    box-shadow: 0 0 80px rgba(0,0,0,0.8);
  }
  .agp-close {
    position: fixed;
    top: 16px;
    right: 20px;
    z-index: 100000;
    background: none;
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 22px;
    line-height: 1;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }
  .agp-close:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
  @keyframes agpFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (max-width: 600px) {
    .agp-container { padding: 0; }
    #agp-iframe { max-width: 100%; height: 100vh; max-height: 100vh; border-radius: 0; }
    .agp-close { top: 12px; right: 12px; }
  }
</style>

<script>
  (function() {
    var SESSION_KEY = 'antara_game_seen';
    var DELAY_MS = 2000;

    function showPopup() {
      var el = document.getElementById('antara-game-popup');
      if (el) el.style.display = 'block';
      document.body.style.overflow = 'hidden';
    }

    window.antaraClosePopup = function() {
      var el = document.getElementById('antara-game-popup');
      if (el) {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.3s';
        setTimeout(function() { el.style.display = 'none'; el.style.opacity = ''; }, 300);
      }
      document.body.style.overflow = '';
      try { sessionStorage.setItem(SESSION_KEY, '1'); } catch(e) {}
    };

    // Close on backdrop click
    document.addEventListener('DOMContentLoaded', function() {
      var backdrop = document.querySelector('.agp-backdrop');
      if (backdrop) backdrop.addEventListener('click', window.antaraClosePopup);

      // Close on Escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') window.antaraClosePopup();
      });

      // Show once per session
      try {
        if (!sessionStorage.getItem(SESSION_KEY)) {
          setTimeout(showPopup, DELAY_MS);
        }
      } catch(e) {
        setTimeout(showPopup, DELAY_MS);
      }
    });
  })();
</script>
