{%- doc -%}
  PDP trust module — renders near the buy box.
  Shows: authenticity guarantee, returns policy, warranty, and low-stock alert.
{%- enddoc -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign inventory_qty = variant.inventory_quantity
  assign track_inventory = variant.inventory_management
  assign show_low_stock = false
  if track_inventory != blank and inventory_qty > 0 and inventory_qty <= 5
    assign show_low_stock = true
  endif
-%}

<div class="pdp-trust-module" aria-label="Product guarantees">
  <ul class="pdp-trust-module__list list-unstyled">
    <li class="pdp-trust-module__item">
      <span class="pdp-trust-module__icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </span>
      <div>
        <span class="pdp-trust-module__label">Authenticity Guaranteed</span>
        <span class="pdp-trust-module__sub">Every piece is quality-verified by our team</span>
      </div>
    </li>
    <li class="pdp-trust-module__item">
      <span class="pdp-trust-module__icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.39"/></svg>
      </span>
      <div>
        <span class="pdp-trust-module__label">Easy Returns</span>
        <span class="pdp-trust-module__sub">30-day hassle-free returns &amp; exchanges</span>
      </div>
    </li>
    <li class="pdp-trust-module__item">
      <span class="pdp-trust-module__icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </span>
      <div>
        <span class="pdp-trust-module__label">Warranty &amp; Repairs</span>
        <span class="pdp-trust-module__sub">12-month warranty · repair service available</span>
      </div>
    </li>
    {%- if show_low_stock -%}
      <li class="pdp-trust-module__item pdp-trust-module__item--low-stock">
        <span class="pdp-trust-module__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </span>
        <div>
          <span class="pdp-trust-module__label">Only {{ inventory_qty }} left in stock</span>
          <span class="pdp-trust-module__sub">Limited edition — this moves fast</span>
        </div>
      </li>
    {%- endif -%}
  </ul>
</div>

{% stylesheet %}
  .pdp-trust-module {
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--padding-md);
    margin-block-start: var(--margin-md);
  }

  .pdp-trust-module__list {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm, 0.75rem);
    margin: 0;
    padding: 0;
  }

  .pdp-trust-module__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .pdp-trust-module__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-block-start: 0.1rem;
    color: var(--color-foreground);
    opacity: 0.65;
  }

  .pdp-trust-module__item > div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .pdp-trust-module__label {
    display: block;
    font-size: var(--font-size--xs);
    font-weight: 500;
    color: var(--color-foreground);
    line-height: 1.4;
  }

  .pdp-trust-module__sub {
    display: block;
    font-size: var(--font-size--2xs);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    line-height: 1.4;
  }

  .pdp-trust-module__item--low-stock .pdp-trust-module__icon,
  .pdp-trust-module__item--low-stock .pdp-trust-module__label {
    color: var(--color-error, #c0392b);
    opacity: 1;
  }
{% endstylesheet %}
